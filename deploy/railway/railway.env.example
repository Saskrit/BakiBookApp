# Railway env template — copy names into Railway dashboard → Variables
# Do NOT commit real secrets to git.

NODE_ENV=production

MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.mongodb.net/BakiBook?retryWrites=true&w=majority

JWT_SECRET=replace_with_long_random_string

# Set after generating Railway domain (no trailing slash)
SERVER_URL=https://your-app.up.railway.app
CLIENT_URL=https://your-app.up.railway.app

EMAIL_USER=
EMAIL_APP_PASSWORD=
EMAIL_FROM=BakiBook <you@gmail.com>

GOOGLE_CLIENT_ID=
CLOUDINARY_URL=

ADMIN_EMAIL=admin@bakibook.com
ADMIN_PASSWORD=change_me
