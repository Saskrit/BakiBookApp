# Local development (copy to mobile/.env)
# Android emulator: http://10.0.2.2:5001/api
# Physical device: http://<YOUR_PC_LAN_IP>:5001/api
EXPO_PUBLIC_API_URL=http://192.168.1.100:5001/api

# Google Sign-In — same Web client ID as VITE_GOOGLE_CLIENT_ID / server GOOGLE_CLIENT_ID.
# EAS builds: mobile/.env is NOT uploaded — set EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID in eas.json too.
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=your_google_oauth_client_id.apps.googleusercontent.com

# Production builds (set in eas.json or EAS secret — NOT in .env for store releases)
# EXPO_PUBLIC_API_URL=https://api.yourdomain.com/api
